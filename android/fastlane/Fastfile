default_platform(:android)

platform :android do

  desc "Build & Deploy to Production"
    lane :deploy do
      # 1. Sicherstellen, dass wir im richtigen Verzeichnis starten
      # Wir sind in android/fastlane, also müssen wir 2 Ebenen hoch zum Flutter-Root

      # Cleanen (optional, aber sicher)
      sh "cd ../.. && flutter clean"

      # Bauen (Das erstellt das AppBundle korrekt mit Version aus pubspec.yaml)
      sh "cd ../.. && flutter build appbundle --release"

      # 2. Upload
      supply(
        track: "production",
        # Der Pfad zum Output ist immer gleich bei Flutter:
        # Vom android-Ordner (wo Fastlane läuft) aus gesehen:
        aab: "../build/app/outputs/bundle/release/app-release.aab",

        # Metadaten überspringen, wenn du nur Code updaten willst
        skip_upload_metadata: true,
        skip_upload_images: true,
        skip_upload_screenshots: true,

        # IMPORTANT:
        # 'completed' = Live immediately for everyone (once Google has reviewed).
        # 'draft' = Upload only, you must press the button in the Console.
        # 'inProgress' + rollout = Percentage rollout (see below).
        release_status: "completed"
      )
    end

  desc "Update only texts & images"
  lane :metadata do
    supply(
      track: "production",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      skip_upload_changelogs: true
    )
  end

end