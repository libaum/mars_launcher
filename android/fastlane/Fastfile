default_platform(:android)

platform :android do

  desc "Builds the app and pushes it IMMEDIATELY to the Production Track 🚀"
  lane :deploy do
    # 1. Clean & build everything
    gradle(task: "clean")
    gradle(
      task: "bundle",
      build_type: "Release"
    )

    # 2. Upload directly to production
    supply(
      track: "production", # <--- The target is now directly 'production'
      aab: "app/build/outputs/bundle/release/app-release.aab",

      # By default, we only upload the code (it's faster).
      # If you have also changed texts, set this to 'false'.
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,

      # IMPORTANT:
      # 'completed' = Live immediately for everyone (once Google has reviewed).
      # 'draft' = Upload only, you must press the button in the Console.
      # 'inProgress' + rollout = Percentage rollout (see below).
      release_status: "completed"
    )
  end

  desc "Update only texts & images in the Store (without new code)"
  lane :metadata do
    supply(
      track: "production",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false
    )
  end

end