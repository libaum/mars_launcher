default_platform(:android)

platform :android do

  # ---------------------------------------------------------------------------
  # Helpers
  # ---------------------------------------------------------------------------

  # Reads the version code (the number after "+" in pubspec.yaml)
  private_lane :current_version_code do
    sh("grep '^version:' ../../pubspec.yaml | sed 's/.*+//'").strip.to_i
  end

  # Builds the Flutter release AAB
  private_lane :build_flutter_aab do
    Dir.chdir("../..") do
      sh("flutter clean")
      sh("flutter pub get")
      sh("flutter build appbundle --release")
    end
  end

  # Uploads the already-built AAB (binary + changelog only, no store listing)
  #   options[:track]  -> "alpha" | "production"
  #   options[:status] -> "draft" | "completed"
  private_lane :upload_aab do |options|
    supply(
      track: options[:track],
      aab: "../build/app/outputs/bundle/release/app-release.aab",
      mapping: "../build/app/outputs/mapping/release/mapping.txt",
      version_code: current_version_code,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false,
      release_status: options[:status]
    )
  end

  # ---------------------------------------------------------------------------
  # Lanes
  # ---------------------------------------------------------------------------

  # 1. Build a new version and upload it to Alpha (Closed Testing, draft).
  desc "Build & upload a new version to Alpha (draft)"
  lane :alpha do
    build_flutter_aab
    upload_aab(track: "alpha", status: "draft")
  end

  # 2. Build a new version and upload it to Production (live after review).
  desc "Build & upload a new version to Production"
  lane :production do
    build_flutter_aab
    upload_aab(track: "production", status: "completed")
  end

  # 3. Update ONLY the store listing (texts, images, screenshots).
  desc "Update the store listing only (texts, images, screenshots)"
  lane :metadata do
    supply(
      track: "production",
      version_code: current_version_code,
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      skip_upload_changelogs: true
    )
  end

  # 4. Upload the existing AAB to Alpha without rebuilding.
  desc "Upload the existing AAB to Alpha (no rebuild, draft)"
  lane :alpha_upload do
    upload_aab(track: "alpha", status: "draft")
  end

  # 5. Upload the existing AAB to Production without rebuilding.
  desc "Upload the existing AAB to Production (no rebuild)"
  lane :production_upload do
    upload_aab(track: "production", status: "completed")
  end

end
